# Ollama Modelfile for the E4B (high-tier) model.
# Creates a local alias "gemma-4-e4b" matching the app's default E4B_MODEL.
#
# Source: unsloth/gemma-4-E4B-it-GGUF (PROPOSAL.md §2)
# Base tag verified against https://ollama.com/library/gemma4/tags on
# 2026-04-29 — Ollama publishes the Gemma 4 E4B build as `gemma4:e4b`
# (9.6GB, 128K context, q4_K_M default; aliased to `gemma4:latest`).
#
# Usage:
#   ./scripts/setup-models.sh
# or, manually:
#   ollama pull gemma4:e4b
#   ollama create gemma-4-e4b -f models/Modelfile.e4b

FROM gemma4:e4b

PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER num_ctx 16384

SYSTEM """You are a helpful AI assistant inside KChat. You run on-device for privacy. You handle reasoning-heavy tasks: drafting PRDs, RFCs, approval prefills, and artifact generation. Provide structured, well-sourced output."""
