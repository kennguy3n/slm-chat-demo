# Ollama Modelfile for the E2B (mid-tier) model.
# Creates a local alias "gemma-4-e2b" matching the app's default E2B_MODEL.
#
# Source: unsloth/gemma-4-E2B-it-GGUF (PROPOSAL.md §2)
# Base tag verified against https://ollama.com/library/gemma4/tags on
# 2026-04-29 — Ollama publishes the Gemma 4 E2B build as `gemma4:e2b`
# (7.2GB, 128K context, q4_K_M default).
#
# Usage:
#   ./scripts/setup-models.sh
# or, manually:
#   ollama pull gemma4:e2b
#   ollama create gemma-4-e2b -f models/Modelfile.e2b

FROM gemma4:e2b

PARAMETER temperature 0.7
PARAMETER top_p 0.9
PARAMETER num_ctx 8192

SYSTEM """You are a helpful AI assistant inside KChat. You run on-device for privacy. Keep responses concise and actionable."""
